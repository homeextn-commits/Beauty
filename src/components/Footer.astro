---
const base = (Astro.base ?? import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
---
<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__title">La Belle</p>
      <p>Salon urody w sercu Warszawy</p>
      <p class="footer__disclaimer"><strong>Projekt edukacyjny.</strong> Ta strona powstała wyłącznie w celach szkoleniowych. Wszystkie zamieszczone tu informacje, nazwy i dane kontaktowe są fikcyjne.</p>
    </div>
    <div class="footer__contacts">
      <div>
        <p class="footer__label">Telefon</p>
        <a href="tel:+48123456789">+48 123 456 789</a>
      </div>
      <div>
        <p class="footer__label">Adres</p>
        <address>ul. Piękna 12, 00-001 Warszawa</address>
      </div>
      <div>
        <p class="footer__label">Email</p>
        <a href="mailto:kontakt@labelle.pl">kontakt@labelle.pl</a>
      </div>
    </div>
  </div>
</footer>
