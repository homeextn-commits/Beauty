---
const base = (Astro.base ?? import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const team = [
  { photo: "/photos/anna.jpg", name: "Анна Соколова", role: "Топ-стилист", exp: "8 лет" },
  { photo: "/photos/maria.jpg", name: "Мария Белова", role: "Колорист", exp: "6 лет" },
  { photo: "/photos/elena.jpg", name: "Елена Краснова", role: "Бьюти-мастер", exp: "5 лет" },
];
---

<section class="team" id="team">
  <div class="team__header">
    <div class="team__label">Команда</div>
    <h2 class="team__title"><em>Мастера своего дела</em></h2>
  </div>

  <div class="team__swiper" id="teamSwiper">
    <div class="team__track" id="teamTrack">
      {team.map(m => (
        <div class="team__slide">
          <div class="team__photo-wrap">
            <img src={base + m.photo} alt={m.name} class="team__photo" />
          </div>
          <div class="team__info">
            <div class="team__name">{m.name}</div>
            <div class="team__role">{m.role}</div>
            <div class="team__exp">Опыт: {m.exp}</div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <div class="swiper-nav">
    <button class="swiper-btn" id="teamPrev">‹</button>
    <div class="swiper-dots" id="teamDots"></div>
    <button class="swiper-btn" id="teamNext">›</button>
  </div>
</section>

<script>
  initSwiper('teamTrack', 'teamPrev', 'teamNext', 'teamDots', 3500);

  function initSwiper(trackId, prevId, nextId, dotsId, autoMs) {
    const track = document.getElementById(trackId);
    const prev = document.getElementById(prevId);
    const next = document.getElementById(nextId);
    const dotsEl = document.getElementById(dotsId);
    if (!track) return;

    const slides = track.children.length;
    let idx = 0;
    let timer;
    let touchStart = null;

    // Create dots
    for (let i = 0; i < slides; i++) {
      const d = document.createElement('button');
      d.className = 'dot' + (i === 0 ? ' active' : '');
      d.addEventListener('click', () => go(i));
      dotsEl?.appendChild(d);
    }

    function go(n) {
      idx = ((n % slides) + slides) % slides;
      track.style.transform = `translateX(${-idx * 100}%)`;
      dotsEl?.querySelectorAll('.dot').forEach((d, i) => d.classList.toggle('active', i === idx));
    }

    function restart() {
      clearInterval(timer);
      if (autoMs) timer = setInterval(() => go(idx + 1), autoMs);
    }

    prev?.addEventListener('click', () => { go(idx - 1); restart(); });
    next?.addEventListener('click', () => { go(idx + 1); restart(); });

    track.parentElement?.addEventListener('touchstart', e => { touchStart = e.touches[0].clientX; clearInterval(timer); });
    track.parentElement?.addEventListener('touchend', e => {
      if (touchStart === null) return;
      const diff = touchStart - e.changedTouches[0].clientX;
      if (Math.abs(diff) > 40) go(diff > 0 ? idx + 1 : idx - 1);
      touchStart = null;
      restart();
    });

    restart();
  }
</script>

<style>
  .team { padding: 3rem 0 2rem; }
  .team__header { text-align: center; padding: 0 1.5rem; margin-bottom: 28px; }
  .team__label {
    font-size: .65rem; font-weight: 500; letter-spacing: .2em;
    text-transform: uppercase; color: var(--accent); margin-bottom: 10px;
  }
  .team__title {
    font-family: var(--font-script);
    font-size: clamp(2rem,8vw,2.8rem);
    font-weight: 300; color: var(--text);
  }
  .team__swiper { overflow: hidden; }
  .team__track {
    display: flex;
    transition: transform .45s cubic-bezier(.25,.46,.45,.94);
  }
  .team__slide { min-width: 100%; padding: 0 1.5rem; }
  .team__photo-wrap {
    height: 65vw; max-height: 400px;
    overflow: hidden; border-radius: 8px;
    border: 1px solid var(--border);
  }
  .team__photo { width: 100%; height: 100%; object-fit: cover; object-position: center top; }
  .team__info { background: var(--surface); padding: 1.25rem 1.5rem; border-radius: 0 0 8px 8px; }
  .team__name { font-family: var(--font-display); font-size: 1.2rem; font-weight: 700; }
  .team__role { font-size: .8rem; color: var(--accent); margin-top: 4px; letter-spacing: .06em; }
  .team__exp { font-size: .75rem; color: var(--muted); margin-top: 2px; }
</style>
