---
const base = (Astro.base ?? import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
---
<section class="cta" id="booking">
  <div class="cta__dots"></div>
  <div class="cta__inner">
    <p class="cta__script"><em>book your visit online</em></p>
    <h2 class="cta__title">SAVE UP TO<br/>30% OFF</h2>
    <p class="cta__desc">Скидка действует при онлайн-записи.<br/>Запишитесь сейчас и получите консультацию бесплатно.</p>
    <a href={base + '/login'} class="cta__btn">Записаться со скидкой</a>
  </div>
</section>

<style>
  .cta {
    position: relative; overflow: hidden;
    background: linear-gradient(135deg, var(--accent) 0%, #c0185a 100%);
    padding: 4rem 1.5rem; text-align: center;
  }
  .cta__dots {
    position: absolute; inset: 0; opacity: .06;
    background-image: radial-gradient(circle,#fff 1px,transparent 1px);
    background-size: 22px 22px;
  }
  .cta__inner { position: relative; z-index: 1; }
  .cta__script {
    font-family: var(--font-script); font-style: italic;
    font-size: clamp(1.2rem,4vw,1.8rem); font-weight: 300;
    color: rgba(255,255,255,.85); margin-bottom: 8px;
  }
  .cta__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem,11vw,5rem); font-weight: 700;
    text-transform: uppercase; color: #fff; line-height: 1; margin-bottom: 16px;
  }
  .cta__desc {
    font-size: .88rem; color: rgba(255,255,255,.75);
    line-height: 1.7; margin-bottom: 32px;
  }
  .cta__btn {
    display: inline-block;
    width: 100%; padding: 1rem;
    font-family: var(--font-body); font-weight: 700;
    font-size: .85rem; letter-spacing: .15em; text-transform: uppercase;
    background: #fff; color: var(--accent); border-radius: 2px;
    transition: all .3s;
  }
  .cta__btn:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(0,0,0,.2); }
</style>
