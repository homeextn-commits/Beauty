---
const base = (Astro.base ?? import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
---
<section class="hero">
  <div class="hero__bg">
    <img src={base + '/photos/hero.jpg'} alt="" class="hero__bg-img" />
    <div class="hero__bg-overlay"></div>
    <div class="hero__bg-gradient"></div>
  </div>

  <div class="container hero__content">
    <div class="hero__label fu" style="animation-delay:.1s">
      <span class="hero__label-line"></span>
      Премиум салон красоты
    </div>

    <h1 class="fu" style="animation-delay:.2s">
      <span class="hero__title-script">ultimate experience</span>
      <span class="hero__title-bold">IN HAIR<br/>CARE</span>
    </h1>

    <p class="hero__desc fu" style="animation-delay:.35s">
      Мы трансформируем ваш образ — от Sun Kiss до Platinum Blonde.
      <span class="hero__badge">
        <strong>30%</strong>
        <small>Скидка при<br/>онлайн записи</small>
      </span>
      Доверьтесь мастерам, которые делают волосы сияющими.
    </p>

    <div class="hero__actions fu" style="animation-delay:.5s">
      <a href={base + '/login'} class="btn btn-primary">Записаться онлайн</a>
      <a href={base + '/#services'} class="btn btn-outline">Наши услуги</a>
    </div>

    <div class="hero__stats fu" style="animation-delay:.65s">
      <div class="hero__stat"><span>800+</span><small>Клиентов</small></div>
      <div class="hero__stat-div"></div>
      <div class="hero__stat"><span>12</span><small>Мастеров</small></div>
      <div class="hero__stat-div"></div>
      <div class="hero__stat"><span>4.9★</span><small>Рейтинг</small></div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    flex-direction: column;
  }
  .hero__bg {
    position: absolute; inset: 0; z-index: 0;
  }
  .hero__bg-img {
    width: 100%; height: 100%; object-fit: cover; object-position: center top;
    opacity: .35;
  }
  .hero__bg-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom, rgba(17,13,13,.7) 0%, rgba(17,13,13,.3) 40%, rgba(17,13,13,.85) 100%);
  }
  .hero__bg-gradient {
    position: absolute; inset: 0;
    background: radial-gradient(ellipse 120% 60% at 50% 100%, rgba(232,53,122,.1) 0%, transparent 60%);
  }
  .hero__content {
    position: relative; z-index: 1;
    padding-top: clamp(7rem,14vh,11rem);
    padding-bottom: 2rem;
    flex: 1;
  }
  .hero__label {
    display: flex; align-items: center; gap: 10px;
    font-size: .68rem; font-weight: 500; letter-spacing: .2em;
    text-transform: uppercase; color: var(--accent);
    margin-bottom: 24px;
  }
  .hero__label-line { width: 28px; height: 1.5px; background: var(--accent); flex-shrink: 0; }
  .hero__title-script {
    display: block;
    font-family: var(--font-script);
    font-style: italic; font-weight: 300;
    font-size: clamp(2.6rem,8vw,5rem);
    line-height: 1.05; color: var(--text);
  }
  .hero__title-bold {
    display: block;
    font-family: var(--font-display);
    font-size: clamp(2.4rem,7.5vw,4.8rem);
    font-weight: 700; line-height: 1;
    text-transform: uppercase;
    margin-bottom: 24px;
  }
  .hero__desc {
    font-size: .9rem; color: var(--muted);
    line-height: 1.8; font-weight: 300;
    max-width: 420px; margin-bottom: 36px;
    overflow: hidden;
  }
  .hero__badge {
    float: right; margin-left: 14px; margin-bottom: 8px;
    background: var(--accent); border-radius: 6px;
    padding: .75rem 1rem; text-align: center;
    box-shadow: 0 8px 24px rgba(232,53,122,.45);
  }
  .hero__badge strong {
    display: block;
    font-family: var(--font-display);
    font-size: 2rem; color: #fff; line-height: 1;
  }
  .hero__badge small {
    display: block; font-size: .58rem; font-weight: 600;
    letter-spacing: .08em; text-transform: uppercase;
    color: rgba(255,255,255,.85); margin-top: 3px; line-height: 1.4;
  }
  .hero__actions {
    display: flex; flex-direction: column; gap: 12px;
    margin-bottom: 48px;
  }
  .hero__actions .btn { width: 100%; }
  .hero__stats {
    display: flex; align-items: center; gap: 24px;
    flex-wrap: wrap;
  }
  .hero__stat { text-align: center; }
  .hero__stat span {
    display: block;
    font-family: var(--font-display);
    font-size: 1.6rem; color: var(--accent); line-height: 1;
  }
  .hero__stat small {
    font-size: .65rem; color: var(--muted);
    letter-spacing: .12em; text-transform: uppercase; margin-top: 3px;
    display: block;
  }
  .hero__stat-div { width: 1px; height: 36px; background: var(--border); }
</style>
