---
import Layout from "../layouts/Layout.astro";
import { createSupabaseClient } from "../lib/supabase";

const base = (Astro.base ?? import.meta.env.BASE_URL ?? "").replace(/\/$/, "");
const supabase = createSupabaseClient(Astro.cookies);
const { data: { session } } = await supabase.auth.getSession();
if (session) return Astro.redirect(base + "/dashboard");

const error = Astro.url.searchParams.get("error");
---

<Layout title="Zaloguj się — La Belle">
  <div class="login">
    <div class="login__card">
      <a href={base + '/'} class="login__logo">
        La <span>Belle</span>
        <small>Salon urody</small>
      </a>
      <h1>Twoje konto</h1>
      <p>Historia wizyt i rezerwacja online</p>

      {error && <div class="login__error">Błąd logowania. Spróbuj ponownie.</div>}

      <div class="login__btns">
        <a href={base + '/auth/google'} class="login__btn login__btn--google">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Zaloguj przez Google
        </a>
        <a href={base + '/auth/facebook'} class="login__btn login__btn--facebook">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
          </svg>
          Zaloguj przez Facebook
        </a>
      </div>

      <p class="login__terms">Logując się, akceptujesz <a href={base + '/privacy'}>politykę prywatności</a></p>
      <a href={base + '/'} class="login__back">← Strona główna</a>
    </div>
  </div>
</Layout>

<style>
  .login {
    min-height: 100svh; display: grid; place-items: center;
    padding: 2rem;
    background: radial-gradient(ellipse 80% 50% at 50% 0%, rgba(232,53,122,.08) 0%, transparent 55%), var(--bg);
  }
  .login__card {
    width: 100%; max-width: 420px;
    background: var(--surface); border: 1px solid var(--border);
    border-radius: 12px; padding: clamp(2rem,5vw,3rem);
    display: flex; flex-direction: column; gap: 18px;
  }
  .login__logo {
    display: flex; align-items: baseline; gap: 4px;
    font-family: var(--font-script); font-style: italic;
    font-size: 1.6rem; font-weight: 300; color: var(--text);
    text-decoration: none; flex-wrap: wrap;
  }
  .login__logo span { color: var(--accent); font-weight: 600; }
  .login__logo small {
    font-size: .5rem; letter-spacing: .22em; text-transform: uppercase;
    color: var(--muted); font-style: normal; margin-left: 4px;
    font-family: var(--font-body); align-self: center;
  }
  h1 { font-family: var(--font-display); font-size: 1.75rem; font-weight: 700; }
  p { font-size: .85rem; color: var(--muted); line-height: 1.6; }
  .login__error {
    background: rgba(220,80,80,.1); border: 1px solid rgba(220,80,80,.3);
    color: #f08080; font-size: .85rem; padding: .75rem 1rem; border-radius: 4px;
  }
  .login__btns { display: flex; flex-direction: column; gap: 12px; }
  .login__btn {
    display: flex; align-items: center; justify-content: center; gap: 10px;
    padding: .9rem; border-radius: 6px;
    font-family: var(--font-body); font-weight: 500; font-size: .875rem;
    transition: all .2s; text-decoration: none;
  }
  .login__btn--google { background: #fff; color: #1f1f1f; }
  .login__btn--google:hover { background: #f5f5f5; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,.2); }
  .login__btn--facebook { background: #1877f2; color: #fff; }
  .login__btn--facebook:hover { background: #166fe5; transform: translateY(-1px); box-shadow: 0 4px 16px rgba(24,119,242,.35); }
  .login__terms { font-size: .7rem; color: var(--muted); text-align: center; }
  .login__terms a { color: var(--accent); text-decoration: underline; }
  .login__back { font-size: .78rem; color: var(--muted); text-align: center; transition: color .2s; }
  .login__back:hover { color: var(--text); }
</style>
